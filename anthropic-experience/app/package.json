{
  "name": "anthropic-experience-review",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "check:root": "node ../scripts/verify-root-layout.mjs",
    "sync:content": "node scripts/sync-public-content.mjs --sync",
    "check:content": "node scripts/sync-public-content.mjs --check",
    "prepare:content": "npm run check:content && node scripts/sync-public-content.mjs --prepare",
    "images:generate": "node scripts/generate-image-derivatives.mjs",
    "build": "npm run prepare:content && node scripts/generate-release-facts.mjs && vite build --mode canonical && node scripts/write-parity-receipt.mjs dist canonical && node scripts/validate-privacy.mjs dist canonical-bundle && node scripts/validate-performance.mjs dist",
    "build:artifact": "npm run prepare:content && node scripts/generate-release-facts.mjs && vite build --mode artifact && node scripts/write-parity-receipt.mjs dist-artifact artifact && node scripts/validate-privacy.mjs dist-artifact artifact-bundle && node scripts/validate-performance.mjs dist-artifact",
    "verify:parity": "node scripts/verify-parity.mjs",
    "preview": "vite preview --host 0.0.0.0",
    "test": "npm run prepare:content && vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:artifact": "playwright test --config playwright.artifact.config.ts",
    "test:dev": "playwright test --config playwright.dev.config.ts",
    "release:verify": "node scripts/verify-release.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "privacy": "node scripts/validate-privacy.mjs . source"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "^6.28.0",
    "vite": "^6.4.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.20.1",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "eslint": "^9.39.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "jsdom": "^25.0.1",
    "typescript": "5.5.4",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
