{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/data/**",
              "components/feedback/**",
              "components/navigation/**",
              "components/surfaces/**",
              "components/transcript/**",
              "ui_kits/research-archive/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Inter, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|icon|size|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: variant, icon, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:user|agent)$/]",
        "message": "<Avatar> variant must be one of 'user' | 'agent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|dot|mono|icon|children|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, dot, mono, icon, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:neutral|info|status|alert)$/]",
        "message": "<Badge> variant must be one of 'neutral' | 'info' | 'status' | 'alert'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Callout'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|icon|title|children|style|key|ref|className|style|children)$/]",
        "message": "<Callout> doesn't accept that prop. Declared props: variant, icon, title, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Callout'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:info|alert)$/]",
        "message": "<Callout> variant must be one of 'info' | 'alert'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|padding|children|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: variant, padding, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|muted|flat)$/]",
        "message": "<Card> variant must be one of 'default' | 'muted' | 'flat'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|style|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='DataColumn'] > JSXAttribute > JSXIdentifier[name!=/^(?:key|header|width|align|mono|key|ref|className|style|children)$/]",
        "message": "<DataColumn> doesn't accept that prop. Declared props: key, header, width, align, mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='DataColumn'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center|right)$/]",
        "message": "<DataColumn> align must be one of 'left' | 'center' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DropdownItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|icon|href|onClick|key|ref|className|style|children)$/]",
        "message": "<DropdownItem> doesn't accept that prop. Declared props: label, icon, href, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetadataItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|key|ref|className|style|children)$/]",
        "message": "<MetadataItem> doesn't accept that prop. Declared props: label, value."
      },
      {
        "selector": "JSXOpeningElement[name.name='ModelSwitchDivider'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|command|note|children|style|key|ref|className|style|children)$/]",
        "message": "<ModelSwitchDivider> doesn't accept that prop. Declared props: icon, command, note, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Navbar'] > JSXAttribute > JSXIdentifier[name!=/^(?:monogram|title|children|style|key|ref|className|style|children)$/]",
        "message": "<Navbar> doesn't accept that prop. Declared props: monogram, title, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ToolLog'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|critical|children|style|key|ref|className|style|children)$/]",
        "message": "<ToolLog> doesn't accept that prop. Declared props: icon, critical, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TranscriptTurn'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|author|model|turn|timestamp|icon|children|style|key|ref|className|style|children)$/]",
        "message": "<TranscriptTurn> doesn't accept that prop. Declared props: variant, author, model, turn, timestamp, icon, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TranscriptTurn'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:user|agent)$/]",
        "message": "<TranscriptTurn> variant must be one of 'user' | 'agent'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
